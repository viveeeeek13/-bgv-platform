{
  "info": {
    "name": "BGV Platform API",
    "description": "Background Verification Platform — complete API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token",   "value": "" },
    { "key": "candidateId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@bgv.com\",\n  \"password\": \"Admin1234\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "if (json.data && json.data.token) {",
                "  pm.collectionVariables.set('token', json.data.token);",
                "  console.log('Token saved:', json.data.token.slice(0,20) + '...');",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@bgv.com\",\n  \"password\": \"Admin1234\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Candidates",
      "item": [
        {
          "name": "Create Candidate",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "if (json.data && json.data.candidate) {",
                "  pm.collectionVariables.set('candidateId', json.data.candidate._id);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/candidates",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"9876543210\",\n  \"aadhaarNumber\": \"123456789012\",\n  \"panNumber\": \"ABCDE1234F\",\n  \"dob\": \"1995-06-15\",\n  \"address\": \"123 MG Road, Bengaluru, Karnataka 560001\"\n}"
            }
          }
        },
        {
          "name": "List Candidates",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/candidates?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "status", "value": "PENDING", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Candidate by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/candidates/{{candidateId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Candidate",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/candidates/{{candidateId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe Updated\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"9876543210\",\n  \"aadhaarNumber\": \"123456789012\",\n  \"panNumber\": \"ABCDE1234F\",\n  \"dob\": \"1995-06-15\",\n  \"address\": \"456 Brigade Road, Bengaluru, Karnataka 560025\"\n}"
            }
          }
        },
        {
          "name": "Get Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/candidates/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Delete Candidate",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/candidates/{{candidateId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Verifications",
      "item": [
        {
          "name": "Start Verification",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/verifications/{{candidateId}}/start",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Verification Logs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/verifications/{{candidateId}}/logs",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Download PDF Report",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reports/{{candidateId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Mock APIs (Internal)",
      "item": [
        {
          "name": "Mock Aadhaar Verify",
          "request": {
            "method": "POST",
            "url": "http://localhost:5000/mock-api/aadhaar/verify",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"aadhaarNumber\": \"123456789012\"\n}"
            }
          }
        },
        {
          "name": "Mock PAN Verify",
          "request": {
            "method": "POST",
            "url": "http://localhost:5000/mock-api/pan/verify",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"panNumber\": \"ABCDE1234F\"\n}"
            }
          }
        }
      ]
    }
  ]
}
